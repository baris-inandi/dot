// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "diff_view_style": "split",
  "search": {
    "center_on_match": true,
  },
  "cli_default_open_behavior": "new_window",
  "colorize_brackets": false,
  "lsp_document_colors": "background",
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "disable_ai": false,
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
      },
      "enable_lsp_tasks": true,
    },
  },
  "file_finder": {
    "file_icons": true,
    "modal_max_width": "medium",
  },
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "openai-subscribed",
      "model": "gpt-5.5",
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "double_click_in_multibuffer": "select",
  "tasks": {
    "enabled": true,
  },
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": false,
  },
  "status_bar": {
    "active_encoding_button": "enabled",
  },
  "word_diff_enabled": true,
  "git_panel": {
    "tree_view": true,
    "dock": "left",
  },
  "unnecessary_code_fade": 0.4,
  "rounded_selection": true,
  "use_system_prompts": false,
  "buffer_line_height": {
    "custom": 1.5,
  },
  "zoomed_padding": true,
  "active_pane_modifiers": {
    "border_size": 0.0,
    "inactive_opacity": 0.8,
  },
  "use_system_window_tabs": false,
  "git": {
    "path_style": "file_name_first",
    "hunk_style": "unstaged_hollow",
    "inline_blame": {
      "padding": 8,
      "enabled": true,
      "show_commit_summary": false,
    },
    "blame": {
      "show_avatar": true,
    },
    "gutter_debounce": 0,
  },
  "ui_font_weight": 400.0,
  "agent_buffer_font_size": 14.0,
  "agent_ui_font_size": 14.0,
  "title_bar": {
    "show_user_picture": true,
    "show_sign_in": true,
    "show_onboarding_banner": true,
    "show_project_items": true,
    "show_user_menu": true,
    "show_menus": true,
    "show_branch_name": true,
  },
  "autoscroll_on_clicks": false,
  "scroll_sensitivity": 1.0,
  "which_key": {
    "delay_ms": 800,
  },
  "ui_font_family": ".SystemUIFont",
  "icon_theme": {
    "mode": "light",
    "light": "VSCode Icons for Zed (Dark NestJS)",
    "dark": "VSCode Icons for Zed (Dark NestJS)",
  },
  "ui_font_size": 14.0,
  "buffer_font_size": 13.0,
  "buffer_font_family": "Biosevka Nerd Font",
  "terminal": {
    "font_weight": 300.0,
    "dock": "right",
    "font_size": 12.0,
  },
  "minimap": {
    "max_width_columns": 60,
    "show": "always",
    "thumb_border": "full",
  },
  "vertical_scroll_margin": 16.0,
  "horizontal_scroll_margin": 16.0,
  "autosave": {
    "after_delay": {
      "milliseconds": 700,
    },
  },
  "inlay_hints": {
    "edit_debounce_ms": 500,
    "enabled": true,
    "show_background": true,
  },
  "project_panel": {
    "dock": "left",
    "sort_mode": "directories_first",
    "bold_folder_labels": false,
    "folder_icons": true,
    "file_icons": true,
    "entry_spacing": "standard",
    "default_width": 220.0,
    "indent_size": 16.0,
  },
  "tabs": {
    "show_close_button": "hover",
    "close_position": "right",
    "git_status": false,
    "file_icons": true,
    "show_diagnostics": "all",
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "telemetry": { "diagnostics": false, "metrics": false },
  "theme": {
    "mode": "system",
    "light": "VSCode Light+",
    "dark": "CodeSandbox",
  },
}
